# ─────────────────────────────────────────
# WhatsApp Cloud API (Meta)
# Get these from: https://developers.facebook.com
# ─────────────────────────────────────────
WA_TOKEN=your_meta_access_token_here
WA_PHONE_NUMBER_ID=your_phone_number_id_here
WA_VERIFY_TOKEN=companiz_webhook_secret_2024   # Any secret string you choose

# ─────────────────────────────────────────
# Supabase
# Use the service_role key (not anon key)
# ─────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...

# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
PORT=3000

# (Optional) Your personal WA number to receive new application alerts
# Format: country code + number, no + sign (e.g. 6512345678 for Singapore)
ADMIN_PHONE=
